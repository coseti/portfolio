# Copy this file to .env.local and fill in your real values.
# .env.local is gitignored - safe for secrets.

# Required for the "Ask Miguel anything" chat widget (gpt-4o-mini)
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Required for the Contact form (-> n8n -> email + WhatsApp)
# Server-side only. Webhook URL where Next.js proxies the form submissions.
N8N_CONTACT_WEBHOOK_URL=
# HMAC SHA256 shared secret. Used to sign requests so n8n can verify they
# come from the portfolio and not from random clients hitting the webhook URL.
# Generate one with:  [guid]::NewGuid().ToString('N') + [guid]::NewGuid().ToString('N')
N8N_CONTACT_SECRET=

# Required for the personalized presentation pages (/p/[token]) video tracking.
# SEPARATE n8n workflow from the contact form — do NOT reuse N8N_CONTACT_* here.
# Server-side only. Webhook URL of the NEW n8n workflow that logs video views.
N8N_TRACK_WEBHOOK_URL=
# HMAC SHA256 shared secret for the tracking webhook (its own, not the contact one).
# Generate one with:  [guid]::NewGuid().ToString('N') + [guid]::NewGuid().ToString('N')
N8N_TRACK_SECRET=

# YouTube video ID for the presentation pages (the part after watch?v= or youtu.be/).
# Public by design (it ends up in the iframe). Leave empty to show an
# "unavailable" message instead of the player — no code change needed to pull it.
NEXT_PUBLIC_PRESENTATION_VIDEO_ID=

# WhatsApp contact number for the hero + contact CTAs. Server-only (NOT
# NEXT_PUBLIC): the /api/wa route 307-redirects to wa.me using this, so the
# number is never shipped in the HTML (anti-scraping, same idea as the email).
# Digits only, with country code, no "+" or spaces — e.g. 34611223344.
# Leave empty to disable: /api/wa then just redirects to the home page.
WHATSAPP_PHONE=

# PRIVATE token -> company map for /p/[token]. Server-only (NOT NEXT_PUBLIC):
# kept out of the repo so target companies and tokens are never public.
# JSON: {"<token>":{"company":"Name","contact":"FirstName (optional)"}, ...}
# Generate a token with: node -e "console.log(require('crypto').randomBytes(5).toString('hex'))"
PRESENTATION_PROSPECTS=
