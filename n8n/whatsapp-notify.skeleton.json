    {
      "parameters": {
        "jsCode": "// Meta calls this once with hub.* query params to verify the callback URL.\nconst q = $input.first().json.query || {};\nconst expected = $env.WHATSAPP_VERIFY_TOKEN;\nif (!expected) { throw new Error('WHATSAPP_VERIFY_TOKEN not readable (set it in n8n env + N8N_BLOCK_ENV_ACCESS_IN_NODE=false, then redeploy)'); }\nconst valid = q['hub.mode'] === 'subscribe' && q['hub.verify_token'] === expected;\nreturn [{ json: { valid: valid, challenge: q['hub.challenge'] || '' } }];"
      },
      "id": "a2222222-2222-2222-2222-222222222222",
      "name": "Check verify token",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 120]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-verify",
              "leftValue": "={{ $json.valid }}",
              "rightValue": "",
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
