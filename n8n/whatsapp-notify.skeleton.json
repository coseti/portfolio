        "responseMode": "responseNode",
        "options": { "rawBody": true }
      },
      "id": "b1111111-1111-1111-1111-111111111111",
      "name": "Webhook messages (POST)",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 460],
      "webhookId": "whatsapp-inbound-messages"
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\n// Meta signs the POST body with the APP SECRET (header x-hub-signature-256: sha256=...).\nconst secret = $env.WHATSAPP_APP_SECRET;\nif (!secret) { throw new Error('WHATSAPP_APP_SECRET not readable (set it in n8n env + N8N_BLOCK_ENV_ACCESS_IN_NODE=false, then redeploy)'); }\nconst item = $input.first();\n// Raw Body is enabled, so HMAC the exact bytes Meta signed, not a re-stringified JSON.\nconst raw = Buffer.from(item.binary.data.data, 'base64').toString('utf8');\nconst headers = item.json.headers || {};\nconst got = (headers['x-hub-signature-256'] || '').replace('sha256=', '');\nconst expected = crypto.createHmac('sha256', secret).update(raw).digest('hex');\nlet valid = false;\ntry {\n  const a = Buffer.from(got);\n  const b = Buffer.from(expected);\n  valid = a.length === b.length && crypto.timingSafeEqual(a, b);\n} catch (e) { valid = false; }\nconst data = JSON.parse(raw);\nreturn [{ json: Object.assign({ valid: valid }, data) }];"
      },
      "id": "b2222222-2222-2222-2222-222222222222",
      "name": "Verify signature",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 460]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict" },
          "conditions": [
            {
              "id": "cond-sig",
              "leftValue": "={{ $json.valid }}",
              "rightValue": "",
              "operator": { "type": "boolean", "operation": "true", "singleValue": true }
            }
          ],
          "combinator": "and"
        },
        "options": {}
