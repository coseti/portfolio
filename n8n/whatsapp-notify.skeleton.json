      "id": "b3333333-3333-3333-3333-333333333333",
      "name": "Signature valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [680, 460]
    },
    {
      "parameters": {
        "jsCode": "// Pull the first inbound message out of Meta's nested payload. Status callbacks\n// (delivered/read) have no 'messages' array -> hasMessage:false (we ignore them).\nconst v = (((($json.entry || [])[0] || {}).changes || [])[0] || {}).value || {};\nconst messages = v.messages || [];\nconst contacts = v.contacts || [];\nif (!messages.length) { return [{ json: { hasMessage: false } }]; }\nconst m = messages[0];\nconst c = contacts[0] || {};\nlet text = '';\nif (m.type === 'text') { text = (m.text || {}).body || ''; } else { text = '[' + m.type + ']'; }\n// Template params reject newlines / long runs of whitespace -> collapse + cap length.\ntext = text.replace(/\\s+/g, ' ').trim().slice(0, 900);\nreturn [{ json: { hasMessage: true, fromNumber: m.from || '', fromName: ((c.profile || {}).name) || 'Desconocido', text: text, type: m.type, messageId: m.id || '', timestamp: m.timestamp || '' } }];"
      },
      "id": "b4444444-4444-4444-4444-444444444444",
      "name": "Extract message",
      "type": "n8n-nodes-base.code",
