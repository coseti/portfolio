# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
# ...but the template (no secrets) IS committed so env vars are documented
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local backup of the previous HTML portfolio (~25MB) — not deployed
/legacy

# internal system documentation — contains infra details (webhooks, HMAC,
# env vars). Local only, NEVER push to the public repo.
/SYSTEM.md

# Playwright MCP screenshots and snapshots (debug artifacts)
/.playwright-mcp/
/*.png

# Local-only outreach prospect data (company names) — never commit
/presentation-prospects.local.txt
